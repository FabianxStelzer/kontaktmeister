# ==========================================================================
# Kontaktmeister - Environment-Variablen
# Alle Variablen muessen in der .env.production auf dem Server gesetzt sein
# Fuer lokale Dev auf http://localhost:3000 umstellen.
# ==========================================================================

# --- Datenbank (in docker-compose ist der Host "postgres") ---
DATABASE_URL="postgresql://kontaktmeister:kontaktmeister@postgres:5432/kontaktmeister?schema=public"

# --- Redis / BullMQ (in docker-compose ist der Host "redis") ---
REDIS_URL="redis://redis:6379"

# --- Auth.js v5 ---
# openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_openssl_rand_base64_32"

# WICHTIG: in Produktion MUSS das die echte Domain sein, sonst Redirect-Loop!
NEXTAUTH_URL="https://app.kontaktmeister.de"
AUTH_URL="https://app.kontaktmeister.de"
AUTH_TRUST_HOST="true"

# --- Verschluesselung von API-Keys in der DB (AES-256) ---
# Exakt 64 Hex-Zeichen (= 32 Byte). openssl rand -hex 32
ENCRYPTION_KEY="CHANGE_ME_openssl_rand_hex_32"

# --- Oeffentliche URLs (fuer Mails, Landingpages, QR-Codes) ---
APP_URL="https://app.kontaktmeister.de"
PUBLIC_URL="https://app.kontaktmeister.de"

# --- Strato SMTP (Standard-Versender, pro Workspace ueberschreibbar) ---
SMTP_HOST="smtp.strato.de"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="no-reply@kontaktmeister.de"
SMTP_PASS="CHANGE_ME"
SMTP_FROM_NAME="Kontaktmeister"
SMTP_FROM_EMAIL="no-reply@kontaktmeister.de"

# --- HeyGen (Workspace-Default, ansonsten pro Workspace in Settings) ---
HEYGEN_API_KEY=""
HEYGEN_API_BASE="https://api.heygen.com"
HEYGEN_WEBHOOK_SECRET="CHANGE_ME"

# --- Superadmin Bootstrap ---
# Erster Superadmin wird beim ersten Start angelegt, sofern noch keiner existiert.
SUPERADMIN_EMAIL="admin@kontaktmeister.de"
SUPERADMIN_PASSWORD="CHANGE_ME_BeimErstenLogin"

# --- Node Env ---
NODE_ENV="production"
